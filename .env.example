APP_NAME=AI Stock Analyzer Bot
APP_ENV=local
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
ENABLE_API_DOCS=true
API_ACCESS_KEY=
METRICS_ACCESS_KEY=

DATABASE_URL=mysql+pymysql://stockbot:password@localhost:3306/stockbot?charset=utf8mb4

TELEGRAM_BOT_TOKEN=
TELEGRAM_MODE=polling
TELEGRAM_WEBHOOK_BASE_URL=
TELEGRAM_WEBHOOK_SECRET=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash
NEWS_API_KEY=
NEWS_API_URL=https://newsapi.org/v2/everything

DEFAULT_AI_PROVIDER=openai
SUMMARY_AI_PROVIDER=openai
ENABLE_MULTI_AI=false

MAX_ANALYSIS_PER_DAY=20
MAX_SCAN_PER_DAY=5
MAX_SCAN_STOCKS=20
SCAN_DELAY_SECONDS=2
AI_REQUEST_TIMEOUT_SECONDS=90
STOCK_DATA_CACHE_SECONDS=300
EXTERNAL_REQUEST_MAX_ATTEMPTS=3
EXTERNAL_REQUEST_BACKOFF_SECONDS=1
SCAN_WORKER_COUNT=1
SCAN_JOB_RETENTION_DAYS=30
STOCK_GROUPS_REMOTE_URL=
ENABLE_SCHEDULED_GROUP_SYNC=false
BACKUP_DIR=/var/backups/ai-stock-analyzer-bot
BACKUP_RETENTION_DAYS=14
LOG_LEVEL=INFO
