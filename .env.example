APP_NAME=AI Stock Analyzer Bot
APP_ENV=local
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
API_ACCESS_KEY=

DATABASE_URL=mysql+pymysql://stockbot:password@localhost:3306/stockbot?charset=utf8mb4

TELEGRAM_BOT_TOKEN=

OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-haiku-4-5
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-v4-flash

DEFAULT_AI_PROVIDER=openai
SUMMARY_AI_PROVIDER=openai
ENABLE_MULTI_AI=false

MAX_ANALYSIS_PER_DAY=20
MAX_SCAN_PER_DAY=5
MAX_SCAN_STOCKS=20
SCAN_DELAY_SECONDS=2
AI_REQUEST_TIMEOUT_SECONDS=90
STOCK_DATA_CACHE_SECONDS=300
LOG_LEVEL=INFO
